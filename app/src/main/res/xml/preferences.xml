<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        android:title="@string/pref_header_hiking_parameters">
        <EditTextPreference
            android:dialogTitle="@string/pref_hiking_par_horSpeed"
            android:id="@+id/pref_hiking_par_horSpeed"
            android:key="pref_hiking_par_horSpeed"
            android:title="@string/pref_hiking_par_horSpeed" />
        <EditTextPreference
            android:id="@+id/pref_hiking_par_vertSpeedClimb"
            android:key="pref_hiking_par_vertSpeedClimb"
            android:defaultValue="2"
            android:title="@string/pref_hiking_par_vertSpeedClimb" />
        <EditTextPreference
            android:id="@+id/pref_hiking_par_vertSpeedDescent"
            android:key="pref_hiking_par_vertSpeedDescent"
            android:defaultValue="3"
            android:title="@string/pref_hiking_par_vertSpeedDescent" />
    </PreferenceCategory>


</PreferenceScreen>
