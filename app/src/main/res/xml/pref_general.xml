<PreferenceScreen xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        android:title="@string/pref_header_hiking_parameters">
        <EditTextPreference
            android:id="@+id/pref_hiking_par_horSpeed"
            android:key="pref_hiking_par_horSpeed"
            android:defaultValue="4200"
            android:summary="string/default_gallery_storage"
            android:title="@string/pref_hiking_par_horSpeed" />
        <EditTextPreference
            android:id="@+id/pref_hiking_par_vertSpeedClimb"
            android:key="pref_hiking_par_vertSpeedClimb"
            android:defaultValue="350"
            android:summary="string/default_gallery_storage"
            android:title="@string/pref_hiking_par_vertSpeedClimb" />
        <EditTextPreference
            android:id="@+id/pref_hiking_par_vertSpeedDescent"
            android:key="pref_hiking_par_vertSpeedDescent"
            android:defaultValue="500"
            android:summary="string/default_gallery_storage"
            android:title="@string/pref_hiking_par_vertSpeedDescent" />
    </PreferenceCategory>

    <PreferenceCategory
        android:title="">

        <SwitchPreference
            android:id="@+id/pref_hiking_par_alarm"
            android:key="pref_hiking_par_alarm"
            android:title="@string/pref_hiking_par_alarm"
            android:summary="@string/pref_hiking_par_alarm_summary"
            android:defaultValue="true"/>

        </PreferenceCategory>

        <!-- NOTE: EditTextPreference accepts EditText attributes. -->
    <!-- NOTE: EditTextPreference's summary should be set to its value by the activity code. -->
    <!-- <Preference android:title="Test Setting"
        android:summary="Text Summary"/>
           -->
